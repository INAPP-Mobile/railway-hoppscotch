# ── Required ──────────────────────────────────────────────────────────────

# PostgreSQL connection string (provided automatically by Railway PostgreSQL plugin)
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=

# Encryption key for sensitive data stored in the database (32 characters exactly)
# Generate one: openssl rand -hex 16
DATA_ENCRYPTION_KEY=

# ── Recommended ───────────────────────────────────────────────────────────

# Comma-separated list of origins allowed for CORS requests.
# Include your Railway public URL here (e.g., https://your-app.up.railway.app)
# Default: http://localhost:3170,http://localhost:3000,http://localhost:3100
WHITELISTED_ORIGINS=

# Secret key used for signing JWT tokens
# Generate one: openssl rand -base64 32
SECRET_KEY=

# ── Optional ──────────────────────────────────────────────────────────────

# Default proxy URL offered to clients (e.g., https://proxy.hoppscotch.io)
# Set to your own proxy endpoint if you run a proxy service
PROXY_APP_URL=

# Enable subpath-based access instead of multiport mode
# When true, all services are served under path prefixes on a single port.
# Recommended for Railway deployments behind the platform's proxy.
# Default: false
# ENABLE_SUBPATH_BASED_ACCESS=true

# ── Advanced ──────────────────────────────────────────────────────────────

# Admin dashboard secret token for API access
# INFRA_TOKEN=

# Whether to trust the X-Forwarded-For header (set to true when behind Railway proxy)
# TRUST_PROXY=true
